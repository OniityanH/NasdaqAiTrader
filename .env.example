# 环境变量配置示例
# 复制此文件为 .env 并填入你的 API Keys

# Alpha Vantage - 股票价格数据
# 申请地址: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# FMP (Financial Modeling Prep) - 基本面数据 + 新闻
# 申请地址: https://site.financialmodelingprep.com/
FMP_KEY=your_fmp_key

# Alpaca - 交易执行
# 申请地址: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
# 设置为 true 使用模拟盘，false 使用实盘
ALPACA_PAPER=true

# DeepSeek - AI 决策
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Finnhub - 新闻数据
# 申请地址: https://finnhub.io/
FINNHUB_KEY=your_finnhub_key

# NewsData.io - 新闻数据
# 申请地址: https://newsdata.io/
NEWSATA_KEY=your_newsdata_key
